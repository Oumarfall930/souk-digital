# ═══════════════════════════════════════
# SOUK DIGITAL — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# ═══════════════════════════════════════

# Supabase (récupérez ces valeurs sur supabase.com → Settings → API)
SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=VOTRE_SERVICE_ROLE_KEY

# JWT Secret (générez une chaîne aléatoire longue)
JWT_SECRET=changez_ceci_avec_une_longue_chaine_aleatoire_securisee_min_32_chars

# Serveur
PORT=3001
NODE_ENV=development

# Admin par défaut (créé automatiquement au premier démarrage)
ADMIN_EMAIL=admin@souk.ma
ADMIN_PASSWORD=admin123
